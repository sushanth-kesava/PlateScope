{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Compile Python Sources",
			"type": "shell",
			"command": "/opt/homebrew/bin/python3",
			"args": [
				"-m",
				"compileall",
				"src"
			],
			"isBackground": false
